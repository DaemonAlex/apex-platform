# APEX Platform - Docker environment
# Copy to .env and edit. NEVER commit .env.

# --- Database ---
DB_DATABASE=apex_db
DB_USERNAME=apex_user
# Use a strong, unique password (min 16 chars recommended)
DB_PASSWORD=CHANGE_ME_strong_db_password

# --- Auth ---
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# --- Initial admin bootstrap ---
# Used by `docker compose exec backend node seed-admin.js` on first deploy.
# Password requirements: min 12 chars, upper + lower + digit + special, no
# repeated triples, no common sequences (123, abc, qwe, ...).
# After first login, change this password from the Profile page and the
# values below can be removed (the seed script is idempotent and refuses
# to run if any user already exists).
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_min_12_chars_Mixed_Case_1!
INITIAL_ADMIN_NAME=APEX Administrator

# --- Web tier ---
# Public host port that nginx listens on (container always exposes 80 internally)
WEB_PORT=8080
# Comma-separated list of allowed origins for CORS (must match how users reach the app)
FRONTEND_URL=http://localhost:8080

# --- Optional: Cisco Control Hub ---
CISCO_MOCK_MODE=true
CISCO_CLIENT_ID=
CISCO_CLIENT_SECRET=
CISCO_ORG_ID=
CISCO_PERSONAL_TOKEN=
