# =============================================================================
# APEX Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and edit. NEVER commit .env to git.
#
# In docker, this file is consumed by `docker compose` and passed through
# to the backend container. In a bare-metal install, copy it to node/.env.
# =============================================================================


# --- Database (REQUIRED) -----------------------------------------------------
# In docker, DB_HOST defaults to the service name `db`. For an external/managed
# PostgreSQL (RDS, Azure DB, on-prem cluster), set DB_HOST to the FQDN and
# enable DB_SSL below.
DB_DATABASE=apex_db
DB_USERNAME=apex_user
# Use a strong, unique password.  Generate:  openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_strong_db_password
# DB_HOST=db
# DB_PORT=5432

# --- Database connection pool (optional, sensible defaults) ------------------
# DB_POOL_MAX=20
# DB_POOL_IDLE_MS=30000
# DB_CONNECT_TIMEOUT_MS=10000

# --- Database TLS (REQUIRED for managed/external PostgreSQL) -----------------
# Set DB_SSL=true to negotiate TLS to the database. Required for AWS RDS,
# Azure Database for PostgreSQL, GCP Cloud SQL, and any cross-network DB.
# Not needed for the in-stack `db` container which is on a private bridge.
#
# DB_SSL=false
#
# Set REJECT_UNAUTHORIZED=false ONLY for self-signed certs in trusted private
# networks. Default is true (verify the server certificate).
# DB_SSL_REJECT_UNAUTHORIZED=true
#
# Path INSIDE THE CONTAINER to a PEM file containing the CA cert to trust.
# Mount the cert into the backend container with a volume:
#   volumes:
#     - ./certs/rds-ca.pem:/etc/apex/db-ca.pem:ro
# DB_SSL_CA=/etc/apex/db-ca.pem
#
# Optional client cert / key for mutual TLS (rare):
# DB_SSL_CERT=/etc/apex/db-client-cert.pem
# DB_SSL_KEY=/etc/apex/db-client-key.pem


# --- Authentication (REQUIRED) -----------------------------------------------
#
# APEX v9.0+ uses RS256 access tokens delivered as httpOnly cookies, paired
# with opaque sliding refresh tokens. The `JWT_SECRET` below is the HS256
# fallback secret kept for the legacy Bearer-in-header flows (download links,
# smoke tests, older clients) that co-exist during the rollout.
#
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Legacy HS256 lifetime. Only used when the RS256 keys aren't loaded.
# Examples: 15m, 24h, 7d. Default 7d.
JWT_EXPIRES_IN=7d

# RS256 keys (REQUIRED for v9.0+). Generate once on the host:
#   mkdir -p secrets
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out secrets/jwt_private.pem
#   openssl rsa -in secrets/jwt_private.pem -pubout -out secrets/jwt_public.pem
#   chmod 400 secrets/jwt_private.pem
# The docker compose file mounts ./secrets -> /app/secrets read-only.
JWT_PRIVATE_KEY_FILE=/app/secrets/jwt_private.pem
JWT_PUBLIC_KEY_FILE=/app/secrets/jwt_public.pem

# Access-token lifetime (short). Must stay short because refresh covers it.
JWT_ACCESS_TTL=15m
# Refresh-token lifetime in days (sliding — any use rotates and extends).
JWT_REFRESH_TTL_DAYS=14


# --- Session cookies ---------------------------------------------------------
# COOKIE_SECURE controls the `Secure` flag. MUST be true in production so the
# cookie is only sent over HTTPS. Set to `false` ONLY for a pure-localhost dev
# setup that isn't using HTTPS (docker-compose.dev.yml does this automatically).
COOKIE_SECURE=true
# COOKIE_DOMAIN leaves the Domain attribute off by default (host-only cookie).
# Set to your eTLD+1 (e.g. apex.example.com) ONLY if you need the cookie to be
# visible to subdomains.
COOKIE_DOMAIN=


# --- TOTP 2FA (REQUIRED if 2FA enrollment is enabled) ------------------------
# AES-256-GCM key used to encrypt stored TOTP secrets at rest. Distinct from
# the JWT keys on purpose: a DB dump must not yield session-signing ability,
# and a JWT-key leak must not decrypt 2FA secrets.
#
# Generate with:  openssl rand -base64 32
TOTP_ENC_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
TOTP_ISSUER=APEX Platform


# --- Drizzle schema pushes ---------------------------------------------------
# The runtime DB user (DB_USERNAME) is CRUD-only and cannot CREATE TABLE.
# Schema pushes via `npm run db:push` need a more privileged login. When
# DDL_USERNAME/DDL_PASSWORD are set, drizzle-kit uses them; otherwise it
# falls back to DB_USERNAME/DB_PASSWORD. Leave these unset in production
# and export them only for the duration of a push.
# DDL_USERNAME=postgres
# DDL_PASSWORD=


# --- Initial admin bootstrap (REQUIRED on first deploy) ----------------------
# Used by `docker compose exec backend node seed-admin.js` to create the first
# admin user. Password requirements: min 12 chars, one upper, one lower, one
# digit, one special, no triple-repeated chars, no common sequences (123, abc,
# qwe, ...).
#
# After first login: change this password from the Profile page, then remove
# INITIAL_ADMIN_PASSWORD from .env. The seed script is idempotent and refuses
# to run if any user already exists.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_min_12_chars_Mixed_Case_1!
INITIAL_ADMIN_NAME=APEX Administrator


# --- Web tier ----------------------------------------------------------------
# Host port that the nginx web container publishes. Default 8080.
WEB_PORT=8080
# Public origin used for CORS. Must match how users reach the app.
# Examples:
#   FRONTEND_URL=https://apex.example.com
#   FRONTEND_URL=https://apex.example.com,https://apex-staging.example.com
FRONTEND_URL=http://localhost:8080


# --- TLS minimum version -----------------------------------------------------
# Enforces a minimum TLS version for ALL outbound HTTPS made by the backend
# (PostgreSQL with DB_SSL, Cisco Control Hub, future integrations). Valid:
# TLSv1.2, TLSv1.3. Do not lower this without a compliance reason.
TLS_MIN_VERSION=TLSv1.2


# --- Logging (optional) ------------------------------------------------------
# Log level: error, warn, info, debug. Default info.
# LOG_LEVEL=info


# --- Test / utility script credentials (optional) ---------------------------
# Used by node/check-reports.js, node/tests/setup.js, and scripts/check.cjs.
# These scripts are dev/ops utilities that authenticate against the running
# backend to exercise endpoints. They are NOT part of the docker runtime
# image - check-reports.js is excluded by .dockerignore.
#
# Create a dedicated low-privilege test user (e.g. via the admin UI) and put
# its credentials here. Do NOT use a real admin account.
#
# APEX_TEST_USER=test-runner@example.com
# APEX_TEST_PASSWORD=
# APEX_API_URL=http://localhost:3001        # for check-reports.js
# APEX_TEST_URL=http://localhost:3001       # for node/tests/setup.js


# --- Optional: Cisco Control Hub integration ---------------------------------
# Set CISCO_MOCK_MODE=true to use static fixture data and skip live API calls.
# Set to false and fill in the credentials to talk to a real org. The Cisco
# client enforces TLS 1.2 minimum independently of TLS_MIN_VERSION above.
CISCO_MOCK_MODE=true
CISCO_CLIENT_ID=
CISCO_CLIENT_SECRET=
CISCO_ORG_ID=
CISCO_PERSONAL_TOKEN=
