# APEX Platform - Docker environment
# Copy to .env and edit. NEVER commit .env.

# --- Database ---
DB_DATABASE=apex_db
DB_USERNAME=apex_user
# Use a strong, unique password (min 16 chars recommended)
DB_PASSWORD=CHANGE_ME_strong_db_password

# --- Auth ---
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# --- Web tier ---
# Public host port that nginx listens on (container always exposes 80 internally)
WEB_PORT=8080
# Comma-separated list of allowed origins for CORS (must match how users reach the app)
FRONTEND_URL=http://localhost:8080

# --- Optional: Cisco Control Hub ---
CISCO_MOCK_MODE=true
CISCO_CLIENT_ID=
CISCO_CLIENT_SECRET=
CISCO_ORG_ID=
CISCO_PERSONAL_TOKEN=
